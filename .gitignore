# Python environment (5 GB — never commit)
.venv/
__pycache__/
*.py[cod]
*.egg-info/

# Local Claude Code harness settings
.claude/

# OS / editor
.DS_Store
*.swp
*.swo

# BFCL (separate env + run artifacts). No trailing slash: in a git worktree the
# env is a symlink to the primary checkout's venv, not a directory.
.venv-bfcl
bfcl_run*/

# tau2-bench (separate env + cloned upstream + run artifacts)
.venv-tau2/
tau2-bench/
tau2_run*/

# vLLM (separate env; pinned torch 2.11.0 -- never commit). No trailing slash:
# symlinked to the primary checkout's venv in a worktree.
.venv-vllm

# SLURM job logs
vulcan/logs/

# BFCL sparsity-sweep raw run artifacts (regenerable; summaries live in results/)
bfcl_runs/
